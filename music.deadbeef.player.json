{
    "app-id": "music.deadbeef.player",
    "branch": "stable",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.llvm22"
    ],
    "command": "deadbeef",
    "finish-args": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--share=network",
        "--socket=pulseaudio",
        "--own-name=org.mpris.MediaPlayer2.DeaDBeeF",
        "--talk-name=org.freedesktop.Notifications",
        "--filesystem=xdg-music",
        "--filesystem=~/.local/lib64/deadbeef",
        "--filesystem=xdg-run/deadbeef:create",
        "--filesystem=xdg-run/pipewire-0:ro"
    ],
    "rename-icon": "deadbeef",
    "rename-desktop-file": "deadbeef.desktop",
    "cleanup": [
        "/include",
        "*.la"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/llvm22/bin",
        "prepend-ld-library-path": "/usr/lib/sdk/llvm22/lib"
    },
    "modules": [
        "shared-modules/intltool/intltool-0.51.json",
        "shared-modules/libmad/libmad.json",
        {
            "name": "libmpg123",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://sourceforge.net/projects/mpg123/files/mpg123/1.33.4/mpg123-1.33.4.tar.bz2/download",
                    "sha256": "3ae8c9ff80a97bfc0e22e89fbcd74687eca4fc1db315b12607f27f01cb5a47d9"
                }
            ]
        },
        {
            "name": "wavpack",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/dbry/WavPack/releases/download/5.9.0/wavpack-5.9.0.tar.gz",
                    "sha256": "0019dfc4b32d63c1392aa264aed2253c1e0c2fb09216f8e2cc269bbfb8bb49b5"
                }
            ]
        },
        {
            "name": "libzip",
            "buildsystem": "cmake",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://libzip.org/download/libzip-1.11.4.tar.gz",
                    "sha256": "82e9f2f2421f9d7c2466bbc3173cd09595a88ea37db0d559a9d0a2dc60dc722e"
                }
            ]
        },
        {
            "name": "libcdio",
            "buildsystem": "autotools",
            "config-opts": [
                "--without-cdda-player",
                "--without-cddb"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/libcdio/libcdio-2.3.0.tar.gz",
                    "sha256": "79b9752c84f4750868b1591565e914ecdea98521e96076929d94be0ac4e5f361"
                }
            ]
        },
        {
            "name": "libcddb",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://sourceforge.net/projects/libcddb/files/libcddb/1.3.2/libcddb-1.3.2.tar.bz2/download",
                    "sha256": "35ce0ee1741ea38def304ddfe84a958901413aa829698357f0bee5bb8f0a223b"
                }
            ]
        },
        {
            "name": "imlib2",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://sourceforge.net/projects/enlightenment/files/imlib2-src/1.12.6/imlib2-1.12.6.tar.bz2/download",
                    "sha256": "7347a1952a7ce0e891d77e3213292d6516bbb777ff7eddeceb2e71299e46ddf0"
                }
            ]
        },
        {
            "name": "libjansson",
            "buildsystem": "cmake",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/akheron/jansson.git",
                    "tag": "v2.15.0"
                }
            ]
        },
        {
            "name": "libopus",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://downloads.xiph.org/releases/opus/opus-1.6.1.tar.gz",
                    "sha256": "6ffcb593207be92584df15b32466ed64bbec99109f007c82205f0194572411a1"
                }
            ]
        },
        {
            "name": "opusfile",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/xiph/opusfile.git",
                    "tag": "v0.12"
                }
            ]
        },
        {
            "name": "libopusenc",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/xiph/libopusenc.git",
                    "tag": "v0.3"
                }
            ]
        },
        {
            "name": "opus-tools",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/xiph/opus-tools.git",
                    "tag": "v0.2"
                }
            ]
        },
        {
            "name": "libfaad2",
            "buildsystem": "cmake",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/knik0/faad2/archive/refs/tags/2.11.2.tar.gz",
                    "sha256": "3fcbd305e4abd34768c62050e18ca0986f7d9c5eca343fb98275418013065c0e"
                }
            ]
        },
        {
            "name": "libblocksruntime",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "http://cdn-fastly.deb.debian.org/debian/pool/main/libb/libblocksruntime/libblocksruntime_0.4.1.orig.tar.gz",
                    "sha256": "7807e18d7d6cabd90f77c8b8a8ebd472516fa4ed6a02df82e0c33b1c5e112abc"
                }
            ]
        },
        {
            "name": "libdispatch",
            "buildsystem": "cmake",
            "builddir": true,
            "build-options": {
                "env": {
                    "CC": "clang",
                    "CXX": "clang++"
                }
            },
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DBlocksRuntime_INCLUDE_DIR=/app/include",
                "-DBlocksRuntime_LIBRARIES=/app/lib/libBlocksRuntime.so"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/swiftlang/swift-corelibs-libdispatch.git",
                    "tag": "swift-6.1.1-RELEASE"
                },
                {
                    "type": "patch",
                    "path": "libdispatch-patches/avoid-libkqueue.patch",
                    "strip-components": 0
                },
                {
                    "type": "patch",
                    "path": "libdispatch-patches/remove-werror.patch",
                    "strip-components": 0
                },
                {
                    "type": "patch",
                    "path": "libdispatch-patches/system-blocksruntime.patch",
                    "strip-components": 0
                }
            ]
        },
        {
            "name": "deadbeef",
            "buildsystem": "autotools",
            "config-opts": [
                "--disable-alsa",
                "--disable-pulse",
                "--disable-oss",
                "CC=clang",
                "CXX=clang++"
            ],
            "build-options": {
                "cflags": "-DUSE_GTK_NATIVE_FILE_CHOOSER",
                "env": {
                    "CC": "clang",
                    "CXX": "clang++"
                }
            },
            "build-commands": [
                "install -D music.deadbeef.player.appdata.xml /app/share/metainfo/music.deadbeef.player.appdata.xml"
            ],
            "post-install": [
                "cp icons/32x32/deadbeef.png /app/"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/DeaDBeeF-Player/deadbeef.git",
                    "tag": "1.10.2"
                },
                {
                    "type": "file",
                    "path": "music.deadbeef.player.appdata.xml"
                },
                {
                    "type": "patch",
                    "path": "default-output-plugin.patch"
                }
            ]
        },
        {
            "name": "pulse2",
            "buildsystem": "meson",
            "config-opts": [
                "--buildtype=release"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/saivert/ddb_output_pulse2.git",
                    "tag": "v1.3"
                },
                {
                    "type": "patch",
                    "path": "pulse-icon.patch"
                }
            ]
        }
    ]
}